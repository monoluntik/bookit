generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum BusinessType {
  HOTEL
  RESTAURANT
  SALON
  COWORKING
  SPORT
  MEDICAL
  CUSTOM
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum PaymentStatus {
  UNPAID
  PENDING
  PAID
  REFUNDED
  PARTIALLY_REFUNDED
}

enum UserRole {
  SUPERADMIN
  BUSINESS_OWNER
  STAFF
  CUSTOMER
}

enum SubscriptionPlan {
  FREE
  PRO
  BUSINESS
}

enum BookingMode {
  FIXED
  FREE_START
}

enum AuthChannel {
  TELEGRAM
  SMS
}

enum AuthChallengeStatus {
  PENDING
  CONFIRMED
  EXPIRED
}

// ─── Platform users ──────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String?
  name      String
  phone     String?  @unique
  role      UserRole @default(CUSTOMER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  telegramChatId   String? @unique
  telegramLinkToken String? @unique

  ownedBusinesses Business[]
  staffMemberships StaffMember[]
  bookings        Booking[]
  reviews         Review[]
  sessions        Session[]
}

// ─── Auth (name + phone + Telegram/SMS confirmation) ────────────────────────

model AuthChallenge {
  id            String   @id @default(cuid())
  phone         String
  name          String
  channel       AuthChannel
  codeHash      String?
  telegramToken String?  @unique
  status        AuthChallengeStatus @default(PENDING)
  attempts      Int      @default(0)
  lastSentAt    DateTime?
  userId        String?
  createdAt     DateTime @default(now())
  expiresAt     DateTime
}

model Session {
  id               String    @id @default(cuid())
  refreshTokenHash String    @unique
  userAgent        String?
  ip               String?
  createdAt        DateTime  @default(now())
  lastUsedAt       DateTime  @default(now())
  expiresAt        DateTime
  revokedAt        DateTime?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Business (tenant) ───────────────────────────────────────────────────────

model Business {
  id               String           @id @default(cuid())
  slug             String           @unique
  name             String
  description      String?
  type             BusinessType
  metadata         Json             @default("{}")
  logoUrl          String?
  images           String[]
  address          String?
  phone            String?
  email            String?
  timezone         String           @default("Asia/Bishkek")
  subscriptionPlan SubscriptionPlan @default(FREE)
  subscriptionActive Boolean        @default(true)
  isActive         Boolean          @default(true)
  bakaiUsername    String?
  bakaiPassword    String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  ownerId  String
  owner    User   @relation(fields: [ownerId], references: [id])

  resources          Resource[]
  staff              StaffMember[]
  bookings           Booking[]
  customRoles        CustomRole[]
  cancellationPolicy CancellationPolicy?
  services           Service[]
  reviews            Review[]
  reminderRules      ReminderRule[]
  translations       BusinessTranslation[]
}

// ─── Content translations (business-authored, customer-facing copy) ─────────
// Original content lives on Business/Resource/Service in the owner's language
// (Russian in practice). These tables hold owner-provided translations for
// the other supported locales; en/kg/uz/kk falls back to the original field
// when no translation row exists for that locale.

model BusinessTranslation {
  id          String   @id @default(cuid())
  locale      String
  name        String?
  description String?
  updatedAt   DateTime @updatedAt

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, locale])
}

model ResourceTranslation {
  id          String   @id @default(cuid())
  locale      String
  name        String?
  description String?
  updatedAt   DateTime @updatedAt

  resourceId String
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([resourceId, locale])
}

model ServiceTranslation {
  id          String   @id @default(cuid())
  locale      String
  name        String?
  description String?
  updatedAt   DateTime @updatedAt

  serviceId String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, locale])
}

// ─── Reminders (Telegram) ────────────────────────────────────────────────────

model ReminderRule {
  id           String   @id @default(cuid())
  offsetMinutes Int     // how long before the booking start to send this reminder
  label        String   // e.g. "За неделю", "За день", "За 3 часа"
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  logs ReminderLog[]

  @@unique([businessId, offsetMinutes])
}

model ReminderLog {
  id        String   @id @default(cuid())
  sentAt    DateTime @default(now())

  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  ruleId    String
  rule      ReminderRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@unique([bookingId, ruleId])
}

// ─── Staff & custom RBAC ─────────────────────────────────────────────────────

model CustomRole {
  id          String   @id @default(cuid())
  name        String
  permissions String[]
  createdAt   DateTime @default(now())

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  staffMembers StaffMember[]

  @@unique([businessId, name])
}

model StaffMember {
  id        String   @id @default(cuid())
  position  String?
  bio       String?
  createdAt DateTime @default(now())

  userId     String
  user       User   @relation(fields: [userId], references: [id])
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  roleId     String?
  role       CustomRole? @relation(fields: [roleId], references: [id])

  resources Resource[]

  @@unique([userId, businessId])
}

// ─── Resources ───────────────────────────────────────────────────────────────

model Resource {
  id          String   @id @default(cuid())
  name        String
  description String?
  images      String[]
  metadata    Json     @default("{}")
  capacity    Int      @default(1)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bookingMode   BookingMode  @default(FIXED)

  businessId    String
  business      Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  staffMemberId String?
  staffMember   StaffMember? @relation(fields: [staffMemberId], references: [id])

  schedules Schedule[]
  bookings  Booking[]
  services  Service[]
  translations ResourceTranslation[]
}

// ─── Schedule (availability rules) ──────────────────────────────────────────

model Schedule {
  id        String   @id @default(cuid())
  dayOfWeek Int[]
  startTime String
  endTime   String
  slotDurationMinutes Int @default(60)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  resourceId String
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  exceptions ScheduleException[]
}

model ScheduleException {
  id        String   @id @default(cuid())
  date      DateTime @db.Date
  reason    String?
  isClosed  Boolean  @default(true)
  startTime String?
  endTime   String?

  scheduleId String
  schedule   Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
}

// ─── Services (optional: for salons, medical, etc.) ─────────────────────────

model Service {
  id          String   @id @default(cuid())
  name        String
  description String?
  durationMinutes Int
  price       Decimal  @db.Decimal(10, 2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  businessId String
  business   Business @relation(fields: [businessId], references: [id])

  resourceId String?
  resource   Resource? @relation(fields: [resourceId], references: [id])

  bookings Booking[]
  translations ServiceTranslation[]
}

// ─── Cancellation policy ─────────────────────────────────────────────────────

model CancellationPolicy {
  id                    String   @id @default(cuid())
  freeCancellationHours Int      @default(24)
  penaltyPercent        Decimal  @db.Decimal(5, 2) @default(0)
  noRefundHours         Int      @default(0)
  updatedAt             DateTime @updatedAt

  businessId String   @unique
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

// ─── Bookings ─────────────────────────────────────────────────────────────────

model Booking {
  id         String        @id @default(cuid())
  status     BookingStatus @default(PENDING)
  source     String        @default("ONLINE") // ONLINE | MANUAL | BLOCK
  startAt    DateTime
  endAt      DateTime
  guestCount Int           @default(1)
  notes      String?
  guestName  String?       // for MANUAL/BLOCK: walk-in customer name
  guestPhone String?       // for MANUAL/BLOCK: walk-in customer phone
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  customerId String
  customer   User     @relation(fields: [customerId], references: [id])
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  resourceId String
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  serviceId  String?
  service    Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  payment       Payment?
  recurringRule RecurringRule?
  review        Review?
  reminderLogs  ReminderLog[]
}

// ─── Payments ────────────────────────────────────────────────────────────────

model Payment {
  id            String        @id @default(cuid())
  status        PaymentStatus @default(UNPAID)
  amount        Decimal       @db.Decimal(10, 2)
  currency      String        @default("KGS")
  transactionId String?
  paidAt        DateTime?
  refundedAt    DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  bookingId String  @unique
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

// ─── Reviews ─────────────────────────────────────────────────────────────────

model Review {
  id        String   @id @default(cuid())
  rating    Int      // 1-5
  comment   String?
  reply     String?  // owner reply
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customerId String
  customer   User     @relation(fields: [customerId], references: [id])
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  bookingId  String   @unique
  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

// ─── Recurring bookings ──────────────────────────────────────────────────────

model RecurringRule {
  id        String   @id @default(cuid())
  rrule     String
  until     DateTime?
  count     Int?
  createdAt DateTime @default(now())

  bookingId    String  @unique
  booking      Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}
