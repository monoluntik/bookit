# PostgreSQL connection (Railway или Neon)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# JWT — сгенерируй: openssl rand -base64 32
JWT_SECRET="change-me-to-random-32-char-string"

# URL фронтенда (Vercel)
FRONTEND_URL="https://your-app.vercel.app"

PORT=4000
NODE_ENV=production

# QA bypass — lets 20 fixed test phone numbers (+996700000001..20) log in with
# code 999999 instead of a real SMS/Telegram code. Leave unset/false in real
# production; only set to "true" deliberately for a QA pass.
ALLOW_TEST_PHONES=false

# Finik (Averspay) payment integration — https://www.finik.kg/docs/web-sdk/
# Publicly reachable base URL of this API, used to build each business's
# webhook URL (e.g. https://your-api.railway.app). Falls back to FRONTEND_URL.
API_PUBLIC_URL="https://your-api.railway.app"
# Beta endpoint during integration testing: https://beta.api.acquiring.averspay.kg
FINIK_API_URL="https://api.acquiring.averspay.kg"
# Finik's public key used to verify incoming webhook signatures — obtain from Finik.
FINIK_WEBHOOK_PUBLIC_KEY=""
# 32-byte key (base64) used to encrypt each business's Finik private key at
# rest. Generate: openssl rand -base64 32
ENCRYPTION_KEY="change-me-to-random-32-byte-base64-key"
